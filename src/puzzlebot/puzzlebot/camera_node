import rclpy
from rclpy.node import Node
from sensor_msgs.msg import CompressedImage
import cv2
import numpy as np

class JetsonFisheyeFiltered(Node):
    def __init__(self):
        super().__init__('jetson_camera_node')
        self.comp_pub = self.create_publisher(CompressedImage, 'camera/image_raw/compressed', 5)
        
        # Pipeline estándar estable
        gst_pipeline = (
            "nvarguscamerasrc wbmode=1 ! "
            "video/x-raw(memory:NVMM), width=320, height=240, framerate=30/1 ! "
            "nvvidconv flip-method=0 ! "
            "video/x-raw, format=BGRx ! "
            "videoconvert ! "
            "video/x-raw, format=BGR ! appsink drop=True max-buffers=1"
        )

        self.cap = cv2.VideoCapture(gst_pipeline, cv2.CAP_GSTREAMER)
        self.timer = self.create_timer(1.0/30.0, self.timer_callback)
        self.get_logger().info("Nodo con Filtro de Color Digital activo")

    def apply_color_filter(self, frame):
        # 1. Convertimos a espacio de color LAB (Luminancia, A: Verde-Rojo, B: Azul-Amarillo)
        # El canal 'A' es donde vive el rosa/rojo.
        lab = cv2.cvtColor(frame, cv2.COLOR_BGR2LAB)
        l, a, b = cv2.split(lab)
        
        # 2. Aplicamos un leve desplazamiento al canal 'A' para neutralizar el rojo
        # Restar un valor pequeño (ej. 5 o 10) quita el tinte rosado global
        a = cv2.subtract(a, 8) 
        
        # 3. Fusionamos y regresamos a BGR
        corrected_lab = cv2.merge((l, a, b))
        result = cv2.cvtColor(corrected_lab, cv2.COLOR_LAB2BGR)
        
        # 4. Ajuste final de contraste/brillo para que el ArUco resalte
        # alpha=1.2 (contraste), beta=-10 (brillo)
        result = cv2.convertScaleAbs(result, alpha=1.1, beta=-5)
        
        return result

    def timer_callback(self):
        if self.cap.grab():
            ret, frame = self.cap.retrieve()
            if ret:
                # APLICAMOS EL FILTRO AQUÍ
                filtered_frame = self.apply_color_filter(frame)
                
                msg = CompressedImage()
                msg.header.stamp = self.get_clock().now().to_msg()
                msg.format = "jpeg"
                
                # Calidad 70 para mantener los 60 FPS
                success, buffer = cv2.imencode('.jpg', filtered_frame, [int(cv2.IMWRITE_JPEG_QUALITY), 70])
                if success:
                    msg.data = buffer.tobytes()
                    self.comp_pub.publish(msg)

def main(args=None):
    rclpy.init(args=args)
    node = JetsonFisheyeFiltered()
    try:
        rclpy.spin(node)
    except KeyboardInterrupt:
        pass
    finally:
        node.cap.release()
        node.destroy_node()
        rclpy.shutdown()